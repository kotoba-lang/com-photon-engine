// Photon_engine clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace photon_engine {

    entity Player {
        id: string @unique
        handle: string
        level: integer
        xp: integer
        region: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Session {
        id: string @unique
        playerId: string
        platform: string
        startedAt: datetime
        durationSec: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Match {
        id: string @unique
        mode: string
        status: string
        playerCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Leaderboard {
        id: string @unique
        name: string
        metric: string
        season: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Inventory {
        id: string @unique
        playerId: string
        itemId: string
        quantity: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Achievement {
        id: string @unique
        playerId: string
        code: string
        unlockedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
